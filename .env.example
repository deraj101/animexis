# Copy this file to .env and fill in your values
# DO NOT commit .env to GitHub — only commit .env.example

PORT=3000
NODE_ENV=production

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Get this from: https://cloud.mongodb.com → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/animexis
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/animexis

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Get this from: https://console.upstash.com → Your Database → Connect → Node.js
# Format: rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_secret_here

# ─── Gmail (for OTP emails) ───────────────────────────────────────────────────
# Generate App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@animexis.com

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=500
